# --- Core (production) ---
# development | production
APP_ENV=development

# PostgreSQL — on Hetzner VPS use docker-compose.hetzner.yml (container on same host)
# DATABASE_URL is set automatically in compose; for manual setups:
DATABASE_URL=postgresql+psycopg://eventradar:eventradar@localhost:5432/eventradar
POSTGRES_USER=eventradar
POSTGRES_PASSWORD=
POSTGRES_DB=eventradar

# Auth — generate with: python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=change-me-in-production

# Firebase Auth — must match VITE_FIREBASE_PROJECT_ID on the frontend
FIREBASE_PROJECT_ID=event-radar-a9c10

# Service-to-service auth (gateway → user-service / events-service)
# Required in production; optional in local dev (middleware disabled when empty)
INTERNAL_SERVICE_TOKEN=

# Swagger / OpenAPI admin panels (/docs) — HTTP Basic auth
# Required in production on api, user-service, and events-service
DOCS_USERNAME=admin
DOCS_PASSWORD=

# Public API gateway
CORS_ORIGINS=http://localhost:5173,http://localhost:5678
TRUSTED_HOSTS=*
# Set to 1 when api runs behind a trusted load balancer (Caddy on Hetzner VPS)
TRUST_PROXY_HEADERS=0
API_PORT=8000

# --- Provider keys ---
# Ticketmaster Discovery API — https://developer.ticketmaster.com/
TICKETMASTER_API_KEY=your_api_key_here

# Default map & nearby-search center (Kraków, Rynek Główny)
DEFAULT_COORD_LAT=50.046943
DEFAULT_COORD_LNG=19.997153

# Provider overrides (optional — inherit DEFAULT_COORD_* when omitted)
# TICKETMASTER_LAT=
# TICKETMASTER_LNG=

TICKETMASTER_RADIUS=50
# API only accepts "km" or "miles" (not "kilometers")
TICKETMASTER_UNIT=km
# Leave empty to search globally (latlong only). PL limits results to Poland.
TICKETMASTER_COUNTRY_CODE=PL
TICKETMASTER_LOCALE=pl-pl
TICKETMASTER_CACHE_TTL_SECONDS=60
TICKETMASTER_PAGE_SIZE=50

# Include user-created community events in events-service aggregation
USER_CUSTOM_EVENTS_ENABLED=false
USER_SERVICE_URL=http://user-service:8002
