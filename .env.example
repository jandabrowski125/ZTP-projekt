# PostgreSQL (cloud URL in production; local compose uses postgres service)
DATABASE_URL=postgresql+psycopg://eventradar:eventradar@localhost:5432/eventradar
JWT_SECRET=change-me-in-production

# Ticketmaster Discovery API — https://developer.ticketmaster.com/
TICKETMASTER_API_KEY=your_api_key_here

# Default map & nearby-search center (Kraków, Rynek Główny)
DEFAULT_COORD_LAT=50.046943
DEFAULT_COORD_LNG=19.997153

# Provider overrides (optional — inherit DEFAULT_COORD_* when omitted)
# TICKETMASTER_LAT=
# TICKETMASTER_LNG=

TICKETMASTER_RADIUS=50
# API only accepts "km" or "miles" (not "kilometers")
TICKETMASTER_UNIT=km
# Leave empty to search globally (latlong only). PL limits results to Poland.
TICKETMASTER_COUNTRY_CODE=PL
TICKETMASTER_LOCALE=pl-pl
TICKETMASTER_CACHE_TTL_SECONDS=60
TICKETMASTER_PAGE_SIZE=50

# Eventbrite (optional second provider) — https://www.eventbrite.com/platform/api
# Public geo search was removed (404/406). TOKEN + ORGANIZATION_ID are both required for EB rows.
EVENTBRITE_TOKEN=
EVENTBRITE_ORGANIZATION_ID=
# EVENTBRITE_LAT=
# EVENTBRITE_LNG=
EVENTBRITE_RADIUS=50
EVENTBRITE_UNIT=km
EVENTBRITE_CACHE_TTL_SECONDS=60
EVENTBRITE_PAGE_SIZE=50
